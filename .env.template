# OpenClaw Workspace Environment Configuration Template
# Location: ~/.openclaw/workspace/.env
# 
# This file contains configuration shared across all OpenClaw projects.
# Values here can be overridden by trading/.env
#
# Setup:
#   1. Copy this file to .env
#   2. Fill in your API keys and email addresses
#   3. Keep this file secure - never commit real keys to version control
#
# Email Configuration (Required for morning-brief, daily-report, regime-alert)
# ============================================================================

# Resend API Key for email delivery
# Get from: https://resend.com/api-keys
# Format: Should start with 're_'
RESEND_API_KEY=re_your_api_key_here

# Sender email address
# This should be a verified domain on your Resend account
FROM_EMAIL=notifications@pinchy.dev

# Recipient email address
# Where email alerts will be sent
TO_EMAIL=ryanwinzenburg@gmail.com


# Telegram Configuration (Optional but recommended for alerts)
# ===========================================================

# Telegram Bot Token for sending messages
# Get from: BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (your personal chat ID)
# Can be found by sending /start to your bot and checking the API response
TELEGRAM_USER_ID=your_chat_id_here

# Telegram Content Bot (if different from main bot)
TELEGRAM_CONTENT_BOT_TOKEN=your_content_bot_token_here


# Interactive Brokers Configuration (For trading features)
# =========================================================

IB_HOST=127.0.0.1
IB_PORT=4002


# System Configuration
# ====================

WORKSPACE_DIR=/Users/pinchy/.openclaw/workspace
