{
  "name": "trading-dashboard-public",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "npm run clean && next dev --no-turbopack",
    "dev:clean:turbo": "npm run clean && next dev --turbopack",
    "postinstall": "prisma generate",
    "build": "next build",
    "build:static": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "build:cf": "opennextjs-cloudflare build",
    "deploy:cf": "opennextjs-cloudflare build && npx wrangler pages deploy .open-next/assets --project-name winzinvest",
    "preview:cf": "opennextjs-cloudflare build && wrangler pages dev .open-next/assets"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-pdf/renderer": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8.4.33",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "wrangler": "^4.73.0"
  }
}
