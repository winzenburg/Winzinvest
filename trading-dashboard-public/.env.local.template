# Mission Control Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Authentication (required) ──────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_generated_secret_here

# The URL your dashboard runs at
NEXTAUTH_URL=http://localhost:3001

# Password to access the dashboard (single-user gate)
DASHBOARD_PASSWORD=your_strong_password_here

# PIN required to ACTIVATE the kill switch (4-8 digits recommended)
KILL_SWITCH_PIN=your_pin_here

# ── System URLs ────────────────────────────────────────────────────────────
# Health check API (Python service)
TRADING_HEALTH_URL=http://127.0.0.1:8000
