## API Route Pattern

### POST for Mutation, GET for Admin Metrics

Every growth feature should have both endpoints:

```typescript
// app/api/[feature]/route.ts

// POST: User action (submit survey, record activation)
export async function POST(req: Request) {
  const session = await getServerSession(authOptions);
  if (!session?.user?.email) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
  }

  // Parse and validate body
  let body: unknown;
  try {
    body = await req.json();
  } catch {
    return NextResponse.json({ error: 'Invalid request body' }, { status: 400 });
  }

  // Type guard validation
  const { field } = body as Record<string, unknown>;
  if (!isValid(field)) {
    return NextResponse.json({ error: 'Invalid field' }, { status: 400 });
  }

  // Get user from session
  const user = await prisma.user.findUnique({
    where: { email: session.user.email },
  });

  // Save the data
  await prisma.feature.create({ data: { userId: user.id, ... } });

  return NextResponse.json({ ok: true });
}

// GET: Admin-only aggregate metrics
export async function GET() {
  const session = await getServerSession(authOptions);
  if (!session?.user?.email) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
  }

  // Check admin role
  const user = await prisma.user.findUnique({
    where: { email: session.user.email },
    select: { role: true },
  });

  if (user?.role !== 'admin') {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 403 });
  }

  // Return aggregated metrics
  const total = await prisma.feature.count();
  const metric = await prisma.feature.aggregate({ _avg: { value: true } });

  return NextResponse.json({ total, metric });
}
```

**Why this pattern:**
- POST = user action, authenticated by session
- GET = admin metrics, double-gated (auth + role check)
- Type guards on all inputs (`body as Record<string, unknown>` → validate)
- Explicit error messages for each failure case

