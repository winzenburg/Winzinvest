## Referral Mechanics Pattern

### Generate Unique Codes on Signup

```typescript
// app/api/waitlist/route.ts

export async function POST(req: Request) {
  const { email, tier, referredBy } = await req.json();
  
  // Generate unique referral code (8-char hex)
  const myReferralCode = randomBytes(4).toString('hex').toUpperCase();
  
  // Validate referral code if provided
  let referrerEntry = null;
  if (referredBy) {
    referrerEntry = await prisma.waitlist.findUnique({
      where: { referralCode: referredBy.toUpperCase() },
    });
  }
  
  // Create entry
  const entry = await prisma.waitlist.create({
    data: {
      email,
      tier,
      referralCode: myReferralCode,
      referredBy: referrerEntry ? referredBy : null,
      source: referrerEntry ? 'referral' : 'landing',
    },
  });
  
  // Increment referrer's count (atomic)
  if (referrerEntry) {
    await prisma.waitlist.update({
      where: { id: referrerEntry.id },
      data: { referralCount: { increment: 1 } },
    });
  }
  
  return NextResponse.json({ ok: true, referralCode: myReferralCode });
}
```

### Capture Referral Code from URL Param

```typescript
// app/components/WaitlistForm.tsx

const searchParams = useSearchParams();
const [referralCode, setReferralCode] = useState<string | null>(null);

useEffect(() => {
  const ref = searchParams.get('ref');
  if (ref) {
    setReferralCode(ref.trim().toUpperCase());
  }
}, [searchParams]);

// Pass to API
await fetch('/api/waitlist', {
  method: 'POST',
  body: JSON.stringify({ 
    email, 
    tier,
    referredBy: referralCode, // ← Include if present
  }),
});
```

**Why this pattern:**
- Code generation: short (8 chars), unique, uppercase (easy to share verbally)
- Validation: check if referrer exists, silently skip if invalid (don't block signup)
- Atomic increment: `{ increment: 1 }` prevents race conditions
- URL param capture: client-side via `useSearchParams()`, passed to API

