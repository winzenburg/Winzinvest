## Modal Component Pattern (Time-Based Triggers)

### Show Once Per Day, Dismiss Permanently After Completion

```typescript
// app/components/PmfSurveyModal.tsx

export default function PmfSurveyModal({ onClose, onComplete }: Props) {
  const [step, setStep] = useState<'main' | 'followup'>('main');
  const [submitting, setSubmitting] = useState(false);

  const handleSubmit = async () => {
    setSubmitting(true);
    try {
      await fetchWithAuth('/api/pmf-survey', {
        method: 'POST',
        body: JSON.stringify({ ...data }),
      });
      onComplete(); // Parent marks as done permanently
    } catch (err) {
      alert('Failed to submit. Please try again.');
    } finally {
      setSubmitting(false);
    }
  };

  // Multi-step flow: main question → follow-up questions
  return (
    <div className="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50">
      {step === 'main' && <MainQuestion onNext={() => setStep('followup')} />}
      {step === 'followup' && <FollowUpQuestions onSubmit={handleSubmit} />}
    </div>
  );
}
```

### Trigger Logic in Parent Component

```typescript
// app/institutional/page.tsx (dashboard)

const [showPmfSurvey, setShowPmfSurvey] = useState(false);
const [pmfSurveyDismissed, setPmfSurveyDismissed] = useState(false);

const fetchData = useCallback(async () => {
  const json = await fetchWithAuth('/api/dashboard').then(r => r.json());
  
  // Check eligibility: D14+, not completed, not dismissed today
  const daysActive = json.user?.createdDaysAgo ?? 0;
  const hasTaken = json.user?.hasTakenPmfSurvey ?? false;
  const dismissedToday = sessionStorage.getItem('pmfSurveyDismissed') === new Date().toDateString();
  
  if (daysActive >= 14 && !hasTaken && !dismissedToday && !pmfSurveyDismissed) {
    setShowPmfSurvey(true);
  }
}, [pmfSurveyDismissed]);

// Render modal conditionally
{showPmfSurvey && (
  <PmfSurveyModal
    onClose={() => {
      setShowPmfSurvey(false);
      setPmfSurveyDismissed(true);
      sessionStorage.setItem('pmfSurveyDismissed', new Date().toDateString());
    }}
    onComplete={() => {
      setShowPmfSurvey(false);
      setPmfSurveyDismissed(true);
    }}
  />
)}
```

**Why this pattern:**
- Modal state lives in parent (not modal itself)
- Session storage for "dismissed today" (ephemeral)
- Database check for "completed ever" (permanent)
- Parent component controls when to show (fetch data decides eligibility)

