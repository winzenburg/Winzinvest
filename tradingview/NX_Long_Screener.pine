//@version=5
indicator("NX Long Screener", shorttitle="NX Longs", overlay=false)

// ============================================================================
// NX LONG SCREENER
// Scans for momentum long candidates matching Mission Control criteria
// Use with TradingView Stock Screener for multi-symbol scanning
// ============================================================================

// === INPUTS ===
show_table = input.bool(true, "Show Info Table")

// === COMPOSITE SCORE ===
momentum_length = 20
momentum_return = (close - close[momentum_length]) / close[momentum_length]
momentum_norm = (math.min(math.max(momentum_return, -0.15), 0.15) / 0.15 + 1) / 2

bb_length = 20
bb_basis = ta.sma(close, bb_length)
bb_dev = 2.0 * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_range = bb_upper - bb_lower
bb_position = bb_range > 0 ? (close - bb_lower) / bb_range : 0.5
bb_position_clamped = math.min(math.max(bb_position, 0), 1)

rsi = ta.rsi(close, 14)
rsi_norm = (rsi - 30) / 40
rsi_norm_clamped = math.min(math.max(rsi_norm, 0), 1)

composite = (momentum_norm * 0.4) + (bb_position_clamped * 0.3) + (rsi_norm_clamped * 0.3)

// === STRUCTURE QUALITY ===
sma20 = ta.sma(close, 20)
sma50 = ta.sma(close, 50)
sma100 = ta.sma(close, 100)
sma200 = ta.sma(close, 200)

mas_above = (close > sma20 ? 1 : 0) + (close > sma50 ? 1 : 0) + (close > sma100 ? 1 : 0) + (close > sma200 ? 1 : 0)
structure_quality = mas_above / 4.0

// === HTF BIAS ===
htf_momentum = (close - close[50]) / close[50]
htf_bias = (math.min(math.max(htf_momentum, -0.15), 0.15) / 0.15 + 1) / 2

// === VOLUME ===
avg_volume_20 = ta.sma(volume, 20)
rvol = volume / avg_volume_20

// === LIQUIDITY GATES ===
avg_dollar_volume = close * avg_volume_20
liquidity_pass = close >= 5.0 and avg_volume_20 >= 500000 and avg_dollar_volume >= 25000000

// === LONG CRITERIA (Mission Control gates) ===

// Tier 1: Basic momentum
tier_1_pass = composite >= 0.08 and structure_quality >= 0.35 and htf_bias >= 0.45

// Tier 2: Strong momentum
tier_2_pass = composite >= 0.25 and structure_quality >= 0.50 and htf_bias >= 0.50

// Tier 3: Extreme momentum (best candidates)
tier_3_pass = composite >= 0.65 and structure_quality >= 0.75 and htf_bias >= 0.60 and rvol >= 1.2

// Overall long signal
long_candidate = liquidity_pass and tier_1_pass

// === PLOTTING ===

// Composite score
plot(composite, "Composite", color=color.new(color.white, 0), linewidth=2)
hline(0.65, "Long Entry", color=color.new(color.green, 50))
hline(0.25, "Tier 2", color=color.new(color.yellow, 70))
hline(0.08, "Tier 1", color=color.new(color.orange, 70))

// Structure quality
plot(structure_quality, "Structure", color=color.new(color.blue, 30), linewidth=1)

// HTF bias
plot(htf_bias, "HTF Bias", color=color.new(color.purple, 30), linewidth=1)

// Background for qualified candidates
bgcolor(long_candidate ? color.new(color.green, 90) : na)

// === INFO TABLE ===

if barstate.islast and show_table
    var table info = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 85), border_width=1)
    
    // Header
    table.cell(info, 0, 0, "NX Long Scan", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.green, 70))
    table.cell(info, 1, 0, syminfo.ticker, text_color=color.white, text_size=size.normal, bgcolor=color.new(color.green, 70))
    
    // Metrics
    table.cell(info, 0, 1, "Composite", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(composite, "#.###"), text_color=composite >= 0.65 ? color.green : composite >= 0.25 ? color.yellow : color.white, text_size=size.small)
    
    table.cell(info, 0, 2, "Structure", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(structure_quality, "#.##") + " (" + str.tostring(mas_above) + "/4)", text_color=structure_quality >= 0.50 ? color.green : color.red, text_size=size.small)
    
    table.cell(info, 0, 3, "HTF Bias", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(htf_bias, "#.###"), text_color=htf_bias >= 0.50 ? color.green : color.red, text_size=size.small)
    
    table.cell(info, 0, 4, "RVol", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(rvol, "#.##") + "x", text_color=rvol >= 1.2 ? color.green : color.white, text_size=size.small)
    
    table.cell(info, 0, 5, "RSI", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 5, str.tostring(rsi, "#.##"), text_color=color.white, text_size=size.small)
    
    table.cell(info, 0, 6, "Price", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 6, str.tostring(close, "#.##"), text_color=color.white, text_size=size.small)
    
    table.cell(info, 0, 7, "Volume", text_color=color.white, text_size=size.small)
    vol_m = volume / 1000000
    table.cell(info, 1, 7, str.tostring(vol_m, "#.##") + "M", text_color=color.white, text_size=size.small)
    
    // Separator
    table.cell(info, 0, 8, "─────────", text_color=color.gray, text_size=size.small)
    table.cell(info, 1, 8, "─────────", text_color=color.gray, text_size=size.small)
    
    // Gates
    table.cell(info, 0, 9, "Liquidity", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 9, liquidity_pass ? "✓ PASS" : "✗ FAIL", text_color=liquidity_pass ? color.green : color.red, text_size=size.small)
    
    table.cell(info, 0, 10, "Tier", text_color=color.white, text_size=size.small)
    tier_text = tier_3_pass ? "Tier 3" : tier_2_pass ? "Tier 2" : tier_1_pass ? "Tier 1" : "None"
    tier_color = tier_3_pass ? color.green : tier_2_pass ? color.yellow : tier_1_pass ? color.orange : color.red
    table.cell(info, 1, 10, tier_text, text_color=tier_color, text_size=size.small)
    
    // Final verdict
    table.cell(info, 0, 11, "VERDICT", text_color=color.white, text_size=size.small)
    verdict = long_candidate ? "🟢 LONG" : "⚪ SKIP"
    verdict_color = long_candidate ? color.green : color.gray
    table.cell(info, 1, 11, verdict, text_color=verdict_color, text_size=size.normal)

// === SCREENER OUTPUT ===
// For TradingView Stock Screener, use these plots as columns:
plot(composite, "NX_Composite", display=display.data_window)
plot(structure_quality, "NX_Structure", display=display.data_window)
plot(htf_bias, "NX_HTF", display=display.data_window)
plot(rvol, "NX_RVol", display=display.data_window)
plot(long_candidate ? 1 : 0, "NX_Long_Signal", display=display.data_window)
plot(tier_3_pass ? 3 : tier_2_pass ? 2 : tier_1_pass ? 1 : 0, "NX_Tier", display=display.data_window)

// === ALERTS ===
alertcondition(long_candidate and not long_candidate[1], "Long Candidate", "{{ticker}}: NX Long Candidate - Composite {{plot_0}}")

// === USAGE ===
// 1. Add this indicator to TradingView
// 2. Open Stock Screener
// 3. Add filter: "NX_Long_Signal" = 1
// 4. Sort by "NX_Tier" descending (Tier 3 first)
// 5. Additional filters:
//    - Market Cap > 1B
//    - Average Volume > 500K
//    - Price > $5
