//@version=5
indicator("NX Composite Score", shorttitle="NX", overlay=false)

// ============================================================================
// NX COMPOSITE SCORE INDICATOR
// Matches Mission Control's composite score calculation
// Components: Momentum (40%) + BB Position (30%) + RSI (30%)
// ============================================================================

// === INPUTS ===
momentum_length = input.int(20, "Momentum Length", minval=1)
bb_length = input.int(20, "Bollinger Band Length", minval=1)
bb_mult = input.float(2.0, "BB Std Dev", minval=0.1, step=0.1)
rsi_length = input.int(14, "RSI Length", minval=1)

// Weights
momentum_weight = input.float(0.4, "Momentum Weight", minval=0, maxval=1, step=0.1)
bb_weight = input.float(0.3, "BB Position Weight", minval=0, maxval=1, step=0.1)
rsi_weight = input.float(0.3, "RSI Weight", minval=0, maxval=1, step=0.1)

// Thresholds (from NX_SCREENER_TECHNICAL_SPEC.md)
show_zones = input.bool(true, "Show Zones")
tier_2_threshold = input.float(0.08, "Tier 2 Threshold", step=0.01)
tier_3_threshold = input.float(0.25, "Tier 3 Threshold", step=0.01)
short_threshold = input.float(0.35, "Short Entry Threshold", step=0.01)
long_threshold = input.float(0.65, "Long Entry Threshold", step=0.01)

// === CALCULATIONS ===

// 1. Momentum (20-day return, normalized to [0, 1])
momentum_return = (close - close[momentum_length]) / close[momentum_length]
momentum_norm = (math.min(math.max(momentum_return, -0.15), 0.15) / 0.15 + 1) / 2

// 2. Bollinger Band Position (0 = lower band, 1 = upper band)
bb_basis = ta.sma(close, bb_length)
bb_dev = bb_mult * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_range = bb_upper - bb_lower
bb_position = bb_range > 0 ? (close - bb_lower) / bb_range : 0.5
bb_position_clamped = math.min(math.max(bb_position, 0), 1)

// 3. RSI Normalized (30-70 range mapped to [0, 1])
rsi = ta.rsi(close, rsi_length)
rsi_norm = (rsi - 30) / 40
rsi_norm_clamped = math.min(math.max(rsi_norm, 0), 1)

// 4. Composite Score (weighted average)
composite = (momentum_norm * momentum_weight) + (bb_position_clamped * bb_weight) + (rsi_norm_clamped * rsi_weight)

// === PLOTTING ===

// Main composite line
plot(composite, "Composite Score", color=color.new(color.white, 0), linewidth=2)

// Zone backgrounds
bgcolor(show_zones and composite >= long_threshold ? color.new(color.green, 85) : na, title="Long Zone")
bgcolor(show_zones and composite <= short_threshold ? color.new(color.red, 85) : na, title="Short Zone")

// Threshold lines
hline(0.5, "Neutral", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(long_threshold, "Long Entry", color=color.new(color.green, 50), linestyle=hline.style_dotted)
hline(short_threshold, "Short Entry", color=color.new(color.red, 50), linestyle=hline.style_dotted)
hline(tier_2_threshold, "Tier 2", color=color.new(color.yellow, 70), linestyle=hline.style_dotted)
hline(tier_3_threshold, "Tier 3", color=color.new(color.orange, 70), linestyle=hline.style_dotted)

// Component plots (optional, for debugging)
plot(momentum_norm, "Momentum", color=color.new(color.blue, 70), linewidth=1, display=display.none)
plot(bb_position_clamped, "BB Position", color=color.new(color.purple, 70), linewidth=1, display=display.none)
plot(rsi_norm_clamped, "RSI Norm", color=color.new(color.orange, 70), linewidth=1, display=display.none)

// === ALERTS ===
alertcondition(ta.crossover(composite, long_threshold), "Long Signal", "NX Composite crossed above {{plot_0}}")
alertcondition(ta.crossunder(composite, short_threshold), "Short Signal", "NX Composite crossed below {{plot_0}}")

// === INFO TABLE ===
if barstate.islast
    var table info_table = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)
    
    table.cell(info_table, 0, 0, "Component", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "Value", text_color=color.white, text_size=size.small)
    
    table.cell(info_table, 0, 1, "Composite", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 1, str.tostring(composite, "#.###"), 
        text_color=composite > long_threshold ? color.green : composite < short_threshold ? color.red : color.white, 
        text_size=size.small)
    
    table.cell(info_table, 0, 2, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 2, str.tostring(momentum_norm, "#.###"), text_color=color.blue, text_size=size.small)
    
    table.cell(info_table, 0, 3, "BB Position", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 3, str.tostring(bb_position_clamped, "#.###"), text_color=color.purple, text_size=size.small)
    
    table.cell(info_table, 0, 4, "RSI Norm", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 4, str.tostring(rsi_norm_clamped, "#.###"), text_color=color.orange, text_size=size.small)
    
    table.cell(info_table, 0, 5, "Raw RSI", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 5, str.tostring(rsi, "#.##"), text_color=color.white, text_size=size.small)
    
    table.cell(info_table, 0, 6, "Signal", text_color=color.white, text_size=size.small)
    signal_text = composite > long_threshold ? "LONG" : composite < short_threshold ? "SHORT" : "NEUTRAL"
    signal_color = composite > long_threshold ? color.green : composite < short_threshold ? color.red : color.gray
    table.cell(info_table, 1, 6, signal_text, text_color=signal_color, text_size=size.small)
    
    table.cell(info_table, 0, 7, "Momentum %", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 7, str.tostring(momentum_return * 100, "#.##") + "%", text_color=color.white, text_size=size.small)

// === INTERPRETATION ===
// Composite Score Ranges:
// 0.0-0.2: Dead/choppy (no clear trend)
// 0.2-0.5: Weak trend
// 0.5-0.8: Strong trend
// 0.8-1.0: Extreme trend (reversal risk)
//
// Long Entry: composite > 0.65 (strong uptrend)
// Short Entry: composite < 0.35 (strong downtrend)
