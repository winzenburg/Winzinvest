//@version=5
indicator("NX Relative Strength (vs SPY)", shorttitle="NX RS", overlay=false)

// ============================================================================
// NX RELATIVE STRENGTH INDICATOR
// Measures stock performance vs SPY over 252 trading days (~1 year)
// Normalized by SPY volatility for comparability
// ============================================================================

// === INPUTS ===
rs_length = input.int(252, "RS Lookback Period", minval=20, tooltip="252 days = ~1 year")
spy_symbol = input.symbol("SPY", "Benchmark Symbol")

// Thresholds
show_zones = input.bool(true, "Show Zones")
strong_outperform = input.float(0.50, "Strong Outperformance", step=0.05)
weak_outperform = input.float(0.02, "Weak Outperformance", step=0.01)
weak_underperform = input.float(-0.50, "Weak Underperformance", step=0.05)

// === CALCULATIONS ===

// Get SPY data
spy_close = request.security(spy_symbol, timeframe.period, close)

// Calculate returns
stock_return = (close - close[rs_length]) / close[rs_length]
spy_return = (spy_close - spy_close[rs_length]) / spy_close[rs_length]

// Calculate SPY volatility (standard deviation of daily returns)
spy_daily_return = (spy_close - spy_close[1]) / spy_close[1]
spy_volatility = ta.stdev(spy_daily_return, rs_length)

// Relative Strength (outperformance normalized by SPY vol)
rs_raw = (stock_return - spy_return) / spy_volatility
rs_normalized = math.min(math.max(rs_raw / 0.5, -1.0), 1.0)

// === PLOTTING ===

// Main RS line
plot(rs_normalized, "RS Normalized", 
    color=rs_normalized > 0 ? color.green : color.red, 
    linewidth=2)

// Zero line
hline(0, "Zero", color=color.new(color.gray, 50), linestyle=hline.style_solid)

// Threshold lines
hline(strong_outperform, "Strong Out", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(weak_outperform, "Weak Out", color=color.new(color.green, 70), linestyle=hline.style_dotted)
hline(weak_underperform, "Weak Under", color=color.new(color.red, 70), linestyle=hline.style_dotted)

// Zone backgrounds
bgcolor(show_zones and rs_normalized > strong_outperform ? color.new(color.green, 85) : na, title="Strong Outperformance")
bgcolor(show_zones and rs_normalized < weak_underperform ? color.new(color.red, 85) : na, title="Strong Underperformance")

// === INFO TABLE ===
if barstate.islast
    var table info_table = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
    
    table.cell(info_table, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "Value", text_color=color.white, text_size=size.small)
    
    table.cell(info_table, 0, 1, "RS (Normalized)", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 1, str.tostring(rs_normalized, "#.###"), 
        text_color=rs_normalized > 0 ? color.green : color.red, 
        text_size=size.small)
    
    table.cell(info_table, 0, 2, "Stock Return", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 2, str.tostring(stock_return * 100, "#.##") + "%", text_color=color.white, text_size=size.small)
    
    table.cell(info_table, 0, 3, "SPY Return", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 3, str.tostring(spy_return * 100, "#.##") + "%", text_color=color.white, text_size=size.small)
    
    table.cell(info_table, 0, 4, "Outperformance", text_color=color.white, text_size=size.small)
    outperf = (stock_return - spy_return) * 100
    table.cell(info_table, 1, 4, str.tostring(outperf, "#.##") + "%", 
        text_color=outperf > 0 ? color.green : color.red, 
        text_size=size.small)
    
    table.cell(info_table, 0, 5, "Signal", text_color=color.white, text_size=size.small)
    signal_text = rs_normalized > strong_outperform ? "STRONG LONG" : 
                  rs_normalized > weak_outperform ? "LONG" : 
                  rs_normalized < weak_underperform ? "SHORT" : 
                  "NEUTRAL"
    signal_color = rs_normalized > weak_outperform ? color.green : 
                   rs_normalized < weak_underperform ? color.red : 
                   color.gray
    table.cell(info_table, 1, 5, signal_text, text_color=signal_color, text_size=size.small)

// === ALERTS ===
alertcondition(ta.crossover(rs_normalized, weak_outperform), "RS Long Signal", "RS crossed above outperformance threshold")
alertcondition(ta.crossunder(rs_normalized, weak_underperform), "RS Short Signal", "RS crossed below underperformance threshold")

// === INTERPRETATION ===
// RS > 0.50: Strong outperformance (top tier long candidate)
// RS > 0.02: Weak outperformance (long candidate)
// RS < -0.50: Strong underperformance (short candidate)
// RS between -0.50 and 0.02: Neutral (no clear edge)
