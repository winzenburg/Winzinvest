// ============================================================================
//  MTF Pullback Entry — 1H Intraday Entry Optimizer (Pine v6)
//
//  Works WITH the NX daily screener. Daily screener finds strong candidates;
//  this script waits for a 1H pullback to key support levels (VWAP, 20 EMA,
//  or prior day's close) before triggering a webhook for better entry price.
//
//  Backtested improvement: 0.2–0.5 ATR better entries → Sharpe 3.78
//
//  Setup:
//    1. Run daily screener → exports candidate symbols
//    2. Add this indicator to a 1H chart for each candidate
//    3. Set alert: "MTF Pullback Entry" → Webhook to your server
//    4. Webhook payload fires execute_webhook_signal with entry_type=pullback
// ============================================================================
//@version=6
indicator("MTF Pullback Entry", overlay=true, max_labels_count=50)

// === INPUTS ===
// Pullback Detection
emaLen       = input.int(20, "Pullback EMA Length", minval=5, maxval=50, group="Pullback")
atrLen       = input.int(14, "ATR Length", minval=5, group="Pullback")
pullbackATR  = input.float(0.5, "Max Pullback Depth (ATR mult)", minval=0.1, maxval=2.0, step=0.1, group="Pullback")
bounceATR    = input.float(0.15, "Bounce Confirmation (ATR mult)", minval=0.05, maxval=0.5, step=0.05, group="Pullback")

// Trend Confirmation (must be in daily uptrend)
useDailyTrend = input.bool(true, "Require Daily Uptrend", group="Trend Filter")
dailySmaLen   = input.int(50, "Daily SMA for Trend", group="Trend Filter")

// VWAP
useVWAP      = input.bool(true, "Use VWAP as Support", group="Support Levels")
useEMA       = input.bool(true, "Use 20 EMA as Support", group="Support Levels")
usePrevClose = input.bool(true, "Use Prior Day Close as Support", group="Support Levels")

// Risk
entryWindow  = input.int(3, "Max Bars in Pullback Zone", minval=1, maxval=10, group="Timing")
cooldownBars = input.int(8, "Cooldown After Signal (bars)", minval=1, maxval=20, group="Timing")

// Webhook fields (passed in alert message)
webhookSecret = input.string("", "Webhook Secret", group="Webhook")

// === CALCULATIONS ===
ema20    = ta.ema(close, emaLen)
atr14    = ta.atr(atrLen)
vwapVal  = ta.vwap(hlc3)
prevClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

// Daily trend filter: price above daily SMA on the daily timeframe
dailySMA  = request.security(syminfo.tickerid, "D", ta.sma(close, dailySmaLen), lookahead=barmerge.lookahead_on)
inUptrend = not useDailyTrend or (close > dailySMA)

// === SUPPORT ZONE DETECTION ===
// Price is "near" a support level if within pullbackATR * ATR
pullbackDepth = pullbackATR * atr14

nearVWAP      = useVWAP and math.abs(low - vwapVal) < pullbackDepth and low <= vwapVal
nearEMA       = useEMA and math.abs(low - ema20) < pullbackDepth and low <= ema20
nearPrevClose = usePrevClose and math.abs(low - prevClose) < pullbackDepth and low <= prevClose

// At least one support touched
touchedSupport = nearVWAP or nearEMA or nearPrevClose

// === BOUNCE CONFIRMATION ===
// Price closes above the support level AND bounces at least bounceATR * ATR from the low
bounceThreshold = bounceATR * atr14
bouncedFromVWAP      = nearVWAP and close > vwapVal and (close - low) > bounceThreshold
bouncedFromEMA       = nearEMA and close > ema20 and (close - low) > bounceThreshold
bouncedFromPrevClose = nearPrevClose and close > prevClose and (close - low) > bounceThreshold

bounceConfirmed = bouncedFromVWAP or bouncedFromEMA or bouncedFromPrevClose

// === VOLUME CONFIRMATION ===
avgVol20 = ta.sma(volume, 20)
volOK    = volume > avgVol20 * 0.7

// === PULLBACK ZONE TRACKING ===
// Count consecutive bars in the pullback zone
var int barsInPullback = 0
if touchedSupport
    barsInPullback := barsInPullback + 1
else
    barsInPullback := 0

inPullbackWindow = barsInPullback > 0 and barsInPullback <= entryWindow

// === COOLDOWN ===
var int barsSinceSignal = 999
barsSinceSignal := barsSinceSignal + 1

// === FINAL SIGNAL ===
pullbackEntry = inUptrend and bounceConfirmed and inPullbackWindow and volOK and barsSinceSignal > cooldownBars

if pullbackEntry
    barsSinceSignal := 0

// Determine which support triggered
supportType = bouncedFromVWAP ? "VWAP" : bouncedFromEMA ? "EMA20" : "PREV_CLOSE"

// === PLOTS ===
plot(ema20, "EMA 20", color=color.new(color.blue, 30), linewidth=2)
plot(vwapVal, "VWAP", color=color.new(color.orange, 40), linewidth=1, style=plot.style_circles)
plot(prevClose, "Prev Close", color=color.new(color.gray, 50), linewidth=1, style=plot.style_cross)

// Entry marker
plotshape(pullbackEntry, title="Pullback Entry", location=location.belowbar,
          color=color.new(color.green, 0), style=shape.triangleup, size=size.normal,
          text="MTF Entry")

// Support zone background
bgcolor(touchedSupport and inUptrend ? color.new(color.green, 92) : na)

// === ALERT ===
alertcondition(pullbackEntry, title="MTF Pullback Entry",
    message='{"entry_type":"pullback","symbol":"' + syminfo.ticker +
            '","action":"BUY","price":' + str.tostring(close) +
            ',"timeframe":"1H","support":"' + supportType +
            '","atr":' + str.tostring(atr14) +
            ',"secret":"' + webhookSecret + '"}')

// === INFO TABLE ===
var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 85))
if barstate.islast
    table.cell(infoTable, 0, 0, "MTF Status", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, inUptrend ? "UPTREND ✓" : "NO TREND ✗",
               text_color=inUptrend ? color.green : color.red, text_size=size.small)

    table.cell(infoTable, 0, 1, "Near Support", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, touchedSupport ? "YES" : "NO",
               text_color=touchedSupport ? color.green : color.gray, text_size=size.small)

    table.cell(infoTable, 0, 2, "Support Type", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, supportType, text_color=color.yellow, text_size=size.small)

    table.cell(infoTable, 0, 3, "ATR(14)", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(atr14, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 4, "Pullback Bars", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(barsInPullback) + "/" + str.tostring(entryWindow),
               text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 5, "Cooldown", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 5, barsSinceSignal > cooldownBars ? "READY" : str.tostring(cooldownBars - barsSinceSignal) + " bars",
               text_color=barsSinceSignal > cooldownBars ? color.green : color.red, text_size=size.small)
