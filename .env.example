# Copy to .env (or use .cursor/.env.local) and fill in. Do not commit.

# GitHub PAT for MCP (loaded by .cursor/run_github_mcp.sh)
GITHUB_PERSONAL_ACCESS_TOKEN=

# TradingView webhook (required for webhook server)
# TV_WEBHOOK_SECRET=your_secret_here

# Trade log DB: SQLite by default (logs/trades.db), or set for Postgres MCP
# DATABASE_URL=sqlite:///path/to/trades.db
# DATABASE_URL=postgresql://localhost:5432/trades
